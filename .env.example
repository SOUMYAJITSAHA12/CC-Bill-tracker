# ── Supabase (https://supabase.com — free tier) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Skip login — open dashboard directly (local dev).
# Set to "false" to enable the real email + password sign-in / sign-up flow at /login.
# When enabled, each signed-in user gets their own private household
# (own cards, bills, profiles). See README "Multi-user signup" section.
#
# Supabase dashboard config to pair with this:
#   Authentication → Providers → Email: Enable
#   Authentication → Settings:
#     - "Confirm email" OFF  → users land on the dashboard immediately after signup
#     - "Confirm email" ON   → users must click the email confirmation link first
#   Authentication → URL Configuration:
#     - Site URL = http://localhost:3000 (or your deployed URL)
#     - Redirect URLs include /auth/callback
SKIP_AUTH=true
# If cards/bills fail with "fetch failed" / TLS errors behind corporate proxy:
# SUPABASE_INSECURE_TLS=true
# Optional fixed household UUID (else auto-created)
# DEV_HOUSEHOLD_ID=
# Secret for cron / GitHub Actions calling /api/fetch/run
FETCH_CRON_SECRET=generate-a-long-random-string

# ── Static user seeding (for `npm run seed:users`) ──
# Creates exactly these two accounts in Supabase Auth so multiple people can
# share one self-hosted CC Bill Tracker without a public signup flow.
# Each user gets their own private household (cards/bills isolated).
# Requires SUPABASE_SERVICE_ROLE_KEY above.
STATIC_USER_1_EMAIL=you@example.com
STATIC_USER_1_PASSWORD=change-me-strong-pw-1
STATIC_USER_2_EMAIL=partner@example.com
STATIC_USER_2_PASSWORD=change-me-strong-pw-2
# Optional: one-time migration. Set to whichever STATIC_USER_*_EMAIL should
# inherit the cards/bills/profiles you already had from the SKIP_AUTH=true
# days (a.k.a. "orphan" households with no auth owner). Leave empty after the
# first successful run.
# MIGRATE_TO_EMAIL=you@example.com

# ── BillDesk Kotak InstaPay (reverse-engineered API) ──
BILLDESK_BASE=https://hexagon.billdesk.com/hgapp-instapay
BILLDESK_APP_ID=KTK03
# Optional: path to JSON with encrypt/decrypt from capture script
BILLDESK_CRYPTO_CONFIG=

# Fetch tuning (batch runner) — parallel biller lanes
# How many different banks/billers to fetch at once (Axis + HDFC + ICICI lane + …)
FETCH_BILLER_PARALLEL=6
# Pause between two cards on the SAME biller only (e.g. 2nd ICICI card after 1st)
BILLER_FETCH_DELAY_MS=4000
